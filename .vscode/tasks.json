{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dev Remote (Backend + Frontend)",
      "type": "shell",
      "command": "./start.sh remote",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "group": "dev-remote",
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Backend",
      "type": "shell",
      "command": "npm run backend",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "group": "dev",
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "group": "dev",
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Dev (Backend + Frontend)",
      "dependsOn": ["Backend", "Frontend"],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
