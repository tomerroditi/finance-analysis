{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev (Backend + Frontend)",
      "request": "launch",
      "type": "node-terminal",
      "command": "echo 'Starting dev servers...'",
      "preLaunchTask": "Dev (Backend + Frontend)"
    },
    {
      "name": "Dev Remote (Tailscale)",
      "request": "launch",
      "type": "node-terminal",
      "command": "echo \"Access at: http://$(/Applications/Tailscale.app/Contents/MacOS/Tailscale ip -4):5173\"",
      "preLaunchTask": "Dev Remote (Backend + Frontend)"
    },
    {
      "name": "Prod (Single Server)",
      "type": "node-terminal",
      "request": "launch",
      "command": "./start.sh prod",
      "cwd": "${workspaceFolder}"
    }
  ]
}
